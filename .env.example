# Vorlage für Umgebungsvariablen.
# Kopiere diese Datei nach .env und passe Werte bei Bedarf an.

# Pfad zur lokalen SQLite-Datenbank (relativ zum Projekt-Root)
DATABASE_URL="file:./prisma/dev.db"

# Öffentliche Basis-URL (für Links in E-Mails)
APP_URL="https://dresdner-tageseltern.de"

# ----------------------------------------------------------------
# SMTP-Versand für die monatlichen Bestätigungsmails
# (genutzt in src/lib/email.ts + den Cron-Routen unter /api/cron/*)
# ----------------------------------------------------------------
SMTP_HOST=smtp.dresdner-tageseltern.de
SMTP_PORT=587
SMTP_USER=plaetze@dresdner-tageseltern.de
SMTP_PASS=hier-das-passwort

# Empfänger der monatlichen Admin-Zusammenfassung (Tag 10)
ADMIN_EMAIL=info@dresdner-tageseltern.de

# Geheimnis zum Schutz der Cron-Routen vor öffentlichem Aufruf.
# Vercel sendet automatisch "Authorization: Bearer <CRON_SECRET>" mit
# jedem Cron-Aufruf. Lokal kann die Variable leer bleiben, dann wird
# der Schutz übersprungen.
CRON_SECRET=

# ----------------------------------------------------------------
# Admin-Bereich (Banner-Buchungen)
# ----------------------------------------------------------------
# Gemeinsames Passwort für den Login unter /admin (Schutz via src/proxy.ts).
# Bleibt die Variable leer, ist der Admin-Bereich NICHT geschützt (nur Dev).
ADMIN_PASSWORT=

# ----------------------------------------------------------------
# Google Analytics 4 + Google Ads (Tracking/Conversion)
# (genutzt in src/components/Analytics.tsx + src/lib/analytics.ts)
# ----------------------------------------------------------------
# GA4-Mess-ID (Format G-XXXXXXX). Nur wenn gesetzt, werden Tag,
# Cookie-Banner und Klick-Tracking aktiv. Lokal leer lassen.
NEXT_PUBLIC_GA_ID=
# Google-Ads-Conversion-ID (Format AW-XXXXXXXXX). Optional.
NEXT_PUBLIC_GADS_ID=
