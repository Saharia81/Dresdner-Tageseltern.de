// Prisma Schema – Dresdner Tages Eltern e.V.
// Doku: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Phase 1 – Steckbriefe & Karte
// ============================================================

enum Beratungsgebiet {
  MALWINA      // Malwina e.V.
  OUTLAW       // Outlaw gGmbH
  KINDERLAND   // KINDERLAND-Sachsen e.V.
}

enum Verpflegung {
  SELBST_GEKOCHT   // "Ich koche selbst"
  CATERING         // "Catering"
}

model Tagesmutter {
  id                    String   @id @default(cuid())
  slug                  String   @unique // URL: /fuer-eltern/tagesmutter-finden/[slug]

  // Personen- & Einrichtungsdaten
  vorname               String
  nachname              String
  einrichtungsname      String
  fotoUrl               String   // rundes Hauptfoto
  einrichtungsfotoUrls  String[]

  // Adresse
  strasse               String
  plz                   String
  stadtteil             String
  latitude              Float?
  longitude             Float?

  // Kontakt
  telefon               String
  email                 String   @unique
  websiteUrl            String?  // eigene Webseite, optional
  anmeldungUrl          String?  // alternativer Anmelde-Link, wenn keine eigene Webseite

  // Betreuung
  oeffnungszeiten       String
  ersatzbetreuung       String
  verpflegung           Verpflegung
  verpflegungHinweis    String?  // abweichender Wortlaut, überschreibt das Standard-Label
  beratungsgebiet       Beratungsgebiet

  // Schmetterling-Partnerschaft
  schmetterling         Boolean  @default(false)
  schmetterlingPartner  String?

  // Mitgliedsdaten
  mitgliedsnummer       String?
  mitgliedSeit          DateTime?

  // E-Mail-Bestätigungs-Flow (monatliche Plätze-Aktualisierung)
  emailToken            String   @unique @default(cuid(2))
  lastConfirmed         DateTime?

  // Sichtbarkeit / Sortierung
  istAktiv              Boolean  @default(true)
  reihenfolge           Int      @default(0)

  // Relationen
  freiePlaetze          FreiePlaetze?
  buchungen             Buchung[]

  erstelltAm            DateTime @default(now())
  aktualisiertAm        DateTime @updatedAt
}

model FreiePlaetze {
  id              String      @id @default(cuid())
  tagesmutter     Tagesmutter @relation(fields: [tagesmutterId], references: [id], onDelete: Cascade)
  tagesmutterId   String      @unique
  platz1Ab        DateTime?
  platz2Ab        DateTime?
  platz3Ab        DateTime?
  platz4Ab        DateTime?
  platz5Ab        DateTime?
  aktualisiertAm  DateTime    @updatedAt
}

// ============================================================
// Phase 1 – Blog / Neuigkeiten
// ============================================================

model BlogPost {
  id                String   @id @default(cuid())
  slug              String   @unique
  titel             String
  kurztext          String   // Vorschau-Text in der Übersicht
  inhaltMd          String   // Markdown-Inhalt
  titelbildUrl      String?
  veroeffentlichtAm DateTime @default(now())
  istEntwurf        Boolean  @default(false)
  aktualisiertAm    DateTime @updatedAt
}

// ============================================================
// Phase 2 – Banner-Buchungssystem (vorbereitet, noch nicht aktiv)
// ============================================================

model Banner {
  id           String    @id @default(cuid())
  nummer       Int       @unique // 1..4 – Verknüpfung zu /banner1–4
  bezeichnung  String    // "Banner 1", "Banner 2" …
  fotoUrl      String    // Banner-Grafik (Detailseite, voll sichtbar)
  fotoBreite   Int?      // Pixelmaße des Fotos (für korrektes Seitenverhältnis)
  fotoHoehe    Int?
  kartenfotoUrl String?  // 16:9-Aufmacher für die Karte auf /banner-buchen
  beispielFotos String[] @default([]) // "so hängt der Banner in echt"-Fotos
  groesse      String    // z. B. "2,0 × 1,0 m"
  beschreibung String
  notizen      String?
  reihenfolge  Int       @default(0)
  istAktiv     Boolean   @default(true)
  buchungen    Buchung[]
}

enum BuchungsStatus {
  ANFRAGE
  BESTAETIGT
  ABGELEHNT
  ABGELAUFEN
}

// Was auf der Banner-Landingpage (/banner1–4) während dieser Buchung gezeigt
// wird: der Steckbrief der Bucherin – oder ein individueller, vom Admin
// freigegebener Inhalt (z. B. Tag der offenen Tür, Sommerfest).
enum BannerInhaltTyp {
  STECKBRIEF
  INDIVIDUELL
}

model Buchung {
  id              String         @id @default(cuid())
  bannerId        String
  banner          Banner         @relation(fields: [bannerId], references: [id])

  // Verknüpftes Profil (gesetzt, sobald die E-Mail einem aktiven
  // Tagesmutter-Profil zugeordnet werden konnte). Bei reinen Anfragen null.
  tagesmutterId   String?
  tagesmutter     Tagesmutter?   @relation(fields: [tagesmutterId], references: [id])

  // Kontaktdaten aus dem Buchungsformular
  kontaktName     String
  kontaktEmail    String

  // Pflicht-Bestätigung: Aufhängen mit Grundstückseigentümer abgesprochen
  grundstueckBestaetigt Boolean

  // Anzeige auf der Bannerseite. STECKBRIEF = Profil der Bucherin zeigen.
  // INDIVIDUELL = freier Inhalt (geht nur nach Admin-Freigabe live).
  anzeigeTyp      BannerInhaltTyp @default(STECKBRIEF)
  // Wunsch-Freitext aus dem Buchungsformular (was beworben werden soll).
  wunsch          String?
  // Vom Admin gepflegter individueller Banner-Inhalt:
  inhaltTitel     String?
  inhaltText      String?
  inhaltBildUrl   String?
  inhaltLinkUrl   String?
  inhaltLinkText  String?

  status          BuchungsStatus @default(ANFRAGE)
  zeitraumStart   DateTime
  zeitraumEnde    DateTime
  notizenAdmin    String?

  // Sicherer Link für Status/Storno
  token           String         @unique @default(cuid(2))

  // Erinnerungs-Versand (Doppelversand vermeiden)
  erinnerung5TageGesendet Boolean @default(false)
  info3TageGesendet       Boolean @default(false)

  erstelltAm      DateTime       @default(now())
  aktualisiertAm  DateTime       @updatedAt

  @@index([bannerId, zeitraumStart, zeitraumEnde])
}
